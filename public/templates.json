[
  {
    "id": "tpl-active-status",
    "name": "Active status",
    "description": "Documents with status = active",
    "query": { "term": { "status": "active" } }
  },
  {
    "id": "tpl-last-24h",
    "name": "Last 24 hours",
    "description": "Time range covering the last 24 hours",
    "query": { "range": { "@timestamp": { "gte": "now-24h" } } }
  },
  {
    "id": "tpl-error-level",
    "name": "Error level",
    "description": "Log records at error level",
    "query": { "match": { "level": "error" } }
  },
  {
    "id": "tpl-has-user",
    "name": "User ID present",
    "description": "Documents where the field exists",
    "query": { "exists": { "field": "user.id" } }
  },
  {
    "id": "tpl-prod-env",
    "name": "Production environment",
    "description": "Documents in the production environment",
    "query": { "term": { "environment": "production" } }
  }
]
