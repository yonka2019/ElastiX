# Copy to .env and fill in. Vite reads .env at startup.
# These vars stay server-side (Vite middleware). They never reach the browser.

# Elasticsearch (for doc count)
ELASTIC_URL=https://your-elastic.example.com:9200
ELASTIC_INDEX=*                # default index pattern queried by /_count
# Auth — use either user/pass OR an API key.
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=changeme
# ELASTIC_API_KEY=abc123...    # base64 "id:api_key" form

# Self-signed certs? Uncomment to skip TLS verify (dev only).
# ELASTIC_INSECURE=true

# Kibana (for "Open in Kibana" button)
# Base origin ONLY — scheme + host (+ port, + base path if behind a proxy).
# Do NOT include /app/... — the app appends /app/discover or /app/dev_tools.
#   Good:  https://kibana.example.com
#   Good:  http://localhost:5601
#   Good:  https://example.com/kibana       (reverse-proxied under /kibana)
#   Bad:   https://kibana.example.com/app/discover
KIBANA_URL=https://your-kibana.example.com
# Data view UUID. With it set, "Open in Kibana" opens Discover with the query
# applied; without it the link falls back to Dev Tools / Console.
# Find it in Kibana → Stack Management → Data Views → click your data view;
# the UUID is the last path segment of the URL, e.g.
#   /app/management/kibana/dataViews/dataView/8a1b2c3d-...   ← that UUID.
# KIBANA_DATA_VIEW_ID=8a1b2c3d-4e5f-6789-abcd-ef0123456789

# MongoDB templates catalog (optional)
# When set, the app serves GET /api/templates from this collection and the
# frontend prefers it over the inline ConfigMap / public/templates.json
# catalog. Collection edits show up on the next page load (30s cache) - no
# restart needed. Document shape:
#   { "id": "...", "name": "...", "description": "...", "query": { ... } }
# (missing "id" falls back to the stringified _id)
# MONGODB_URI works too (alias). With auth / Atlas:
#   MONGO_URL=mongodb://user:pass@host:27017
#   MONGO_URL=mongodb+srv://user:pass@cluster0.example.mongodb.net
# MONGO_URL=mongodb://localhost:27017
# MONGO_DB=elastix                       # default: elastix
# MONGO_TEMPLATES_COLLECTION=templates   # default: templates

# Remote query service (optional) — powers the Templates panel's
# "Fetch from remote" button. The app proxies it server-side:
#   browser → GET /api/templates-remote?name=<name>
#   server  → GET ${TEMPLATES_REMOTE_URL}/<name>   (name URL-encoded into path)
# and expects a JSON body shaped like { "query": { ... } }; the unwrapped
# `query` becomes a draggable card you can drop into a block.
#
# Read server-side at runtime (like the vars above) — set it on the container
# with no rebuild. The fetch is server-to-server, so the remote service needs
# no CORS for the browser. Unset → the "Fetch from remote" button is disabled.
# TEMPLATES_REMOTE_URL=https://your-query-service.example.com/queries
# Display name shown in the button — "Fetch from <name>". Unset → "remote".
# TEMPLATES_REMOTE_NAME=Ruletta
# Optional bearer token for the remote service. When set, the proxy sends
# `Authorization: Bearer <token>` upstream. In K8s, source it from a
# ConfigMap (or, preferred for secrets, a Secret) into this env var.
# TEMPLATES_REMOTE_TOKEN=eyJhbGciOi...
