# Copy to .env and fill in. Vite reads .env at startup.
# These vars stay server-side (Vite middleware). They never reach the browser.

# Elasticsearch (for doc count)
ELASTIC_URL=https://your-elastic.example.com:9200
ELASTIC_INDEX=*                # default index pattern queried by /_count
# Auth — use either user/pass OR an API key.
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=changeme
# ELASTIC_API_KEY=abc123...    # base64 "id:api_key" form

# Self-signed certs? Uncomment to skip TLS verify (dev only).
# ELASTIC_INSECURE=true

# Kibana (for "Open in Kibana" button)
# Base origin ONLY — scheme + host (+ port, + base path if behind a proxy).
# Do NOT include /app/... — the app appends /app/discover or /app/dev_tools.
#   Good:  https://kibana.example.com
#   Good:  http://localhost:5601
#   Good:  https://example.com/kibana       (reverse-proxied under /kibana)
#   Bad:   https://kibana.example.com/app/discover
KIBANA_URL=https://your-kibana.example.com
# Data view UUID. With it set, "Open in Kibana" opens Discover with the query
# applied; without it the link falls back to Dev Tools / Console.
# Find it in Kibana → Stack Management → Data Views → click your data view;
# the UUID is the last path segment of the URL, e.g.
#   /app/management/kibana/dataViews/dataView/8a1b2c3d-...   ← that UUID.
# KIBANA_DATA_VIEW_ID=8a1b2c3d-4e5f-6789-abcd-ef0123456789
